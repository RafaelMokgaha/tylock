rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // --- USER PROFILES ---
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // --- CHANNELS (Discord-like) ---
    match /channels/{channelId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // --- CHANNEL MESSAGES ---
    match /channelMessages/{channelId}/messages/{messageId} {
      allow read, write: if isAuthenticated();
    }

    // --- GLOBAL COMMUNITY CHAT ---
    match /globalChat/{messageId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // --- DIRECT MESSAGES ---
    match /directMessages/{conversationId}/messages/{messageId} {
      allow read, write: if isAuthenticated() && 
        (conversationId.split('--')[0] == request.auth.token.email || conversationId.split('--')[1] == request.auth.token.email);
    }

    // --- ANNOUNCEMENTS ---
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAuthenticated(); // In a production app, we would restrict this to an admin role
    }

    // --- VOICE SIGNALING & PRESENCE ---
    match /voicePresence/{document=**} {
      allow read, write: if isAuthenticated();
    }

    match /voiceSignaling/{document=**} {
      allow read, write: if isAuthenticated();
    }

    // --- USER REQUESTS ---
    match /gameRequests/{requestId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && resource.data.userEmail == request.auth.token.email;
    }

    match /onlineFixRequests/{requestId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && resource.data.userEmail == request.auth.token.email;
    }

    // --- BYPASS REQUESTS ---
    match /bypassRequests/{requestId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && resource.data.userEmail == request.auth.token.email;
    }

    // --- HELP / SUPPORT MESSAGES ---
    match /helpMessages/{messageId} {
      allow read, write: if true;
    }
    // --- FRIEND REQUESTS ---
    match /friendRequests/{requestId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.from == request.auth.token.email || resource.data.to == request.auth.token.email);
      allow create: if isAuthenticated() && request.resource.data.from == request.auth.token.email;
      allow update: if isAuthenticated() && (resource.data.to == request.auth.token.email || resource.data.from == request.auth.token.email);
      allow delete: if isAuthenticated() && (resource.data.to == request.auth.token.email || resource.data.from == request.auth.token.email);
    }

    // --- FRIENDSHIPS ---
    match /friendships/{friendshipId} {
      allow read: if isAuthenticated() && (request.auth.token.email in resource.data.users);
      allow create: if isAuthenticated(); // Should be created by the accepting user
      allow update, delete: if isAuthenticated() && (request.auth.token.email in resource.data.users);
    }

    // --- CONVERSATION METADATA (Unread tracking) ---
    match /conversations/{conversationId}/metadata/{userId} {
      allow read, write: if isAuthenticated() && userId == request.auth.uid;
    }
  }
}
