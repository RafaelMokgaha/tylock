{
  "name": "tylock-games-website",
  "private": true,
  "version": "0.0.0",
  "author": "Tylock Games",
  "description": "Premium Gaming Hub",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "dist": "npm run electron:build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "express": "^5.2.1",
    "firebase": "^12.10.0",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "url": "^0.11.4",
    "uuid": "^13.0.0",
    "vite": "^7.2.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.tylock.games",
    "productName": "TYLOCK GAMES",
    "directories": {
      "output": "dist_electron"
    },
    "asar": false,
    "files": [
      "dist/**/*",
      "build/**/*",
      "main.js"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "shortcutName": "TYLOCK GAMES"
    }
  }
}